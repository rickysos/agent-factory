{
  "name": "agent-factory",
  "version": "0.1.0",
  "description": "AI Agent Development Platform - Create, deploy, and manage AI agents",
  "main": "src/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "api:dev": "node src/server/api-server.js",
    "start:api": "NODE_ENV=production node src/server/api-server.js",
    "worker:dev": "node src/server/worker-server.js",
    "start:worker": "NODE_ENV=production node src/server/worker-server.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:reset": "docker-compose down -v && docker-compose up -d --build",
    "db:migrate": "node scripts/db-migrate.js",
    "db:seed": "node scripts/db-seed.js",
    "agents:deploy": "node scripts/deploy-agents.js",
    "agents:list": "node scripts/list-agents.js",
    "agents:create": "node scripts/create-agent.js",
    "queue:stats": "node scripts/queue-stats.js",
    "queue:monitor": "node scripts/queue-monitor.js"
  },
  "keywords": [
    "ai",
    "agents",
    "automation",
    "openclaw",
    "llm",
    "workflow"
  ],
  "author": "Ricky Brandes",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.25.0",
    "axios": "^1.6.0",
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.22.1",
    "ioredis": "^5.10.0",
    "next": "^15.0.0",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "15.0.0",
    "jest": "^29.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
